# @hiko/signin-headless — local dev config, read by `npm run dev` (Vite).
# Copy this file to `.env` and fill in the values. All four are PUBLIC values
# (there are no secrets here — a public OAuth client id is, by definition, not
# confidential), so it is safe to commit them in your own storefront if you wish.

# 1) Your Shopify store's permanent domain (the *.myshopify.com one).
#    Where to get it: Shopify admin → Settings → Domains, or read it from your
#    admin URL (admin.shopify.com/store/<handle> → <handle>.myshopify.com).
VITE_SHOP=your-shop.myshopify.com

# 2) Customer Account API PUBLIC client id (drives the browser PKCE login).
#    Where to get it: Shopify admin → Sales channels → Headless → your storefront →
#    "Customer Account API" → "Application setup". (Install the Headless sales
#    channel first if it isn't there.) That screen lists the Client ID and is also
#    where you set JavaScript Origins + Redirect/Callback + Logout URIs
#    (see README → "Required Shopify setup"). NOTE: it is NOT under
#    Settings → Customer accounts. Public — safe to ship.
VITE_CLIENT_ID=

# 3) Your store's NUMERIC shop id (used to build the auth base URL
#    https://shopify.com/authentication/<SHOP_ID>).
#    Where to get it: the same Headless → Customer Account API → Application setup
#    screen lists shopId alongside the Client ID. It is also visible in
#    Settings → Customer accounts → URL, shown as https://shopify.com/<SHOP_ID>/account.
#    (Also the trailing digits of the Admin API `shop { id }` gid,
#    e.g. gid://shopify/Shop/27994783882 → 27994783882.)
VITE_SHOP_ID=

# 4) The HIKO Social Login Plus server that serves per-shop widget config
#    (GET /headless/config?shop=...). Leave as the default unless you self-host HIKO.
VITE_CONFIG_SERVER=https://signin.hiko.software
