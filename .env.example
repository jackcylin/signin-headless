# signin-headless — local dev config, read by `npm run dev` (Vite).
# Copy this file to `.env` and fill in VITE_SHOP and VITE_CONFIG_SERVER.
#
# BROKER MODEL: The storefront only needs `shop` + `config-server`.
# The Customer Account API client id, client secret, and shop id are configured
# ONCE by the merchant in the HIKO admin (admin → Integrations →
# "Customer Account API"). The storefront developer does NOT need to touch
# Shopify's Headless sales channel or register any OAuth URIs.

# 1) Your Shopify store's permanent domain (the *.myshopify.com one).
#    Where to get it: Shopify admin → Settings → Domains, or read it from your
#    admin URL (admin.shopify.com/store/<handle> → <handle>.myshopify.com).
VITE_SHOP=your-shop.myshopify.com

# 2) The HIKO Social Login Plus server that serves per-shop widget config and
#    acts as the login broker (handles OAuth/PKCE server-side, issues an opaque
#    session token back to the browser). Leave as the default unless you
#    self-host HIKO.
VITE_CONFIG_SERVER=https://signin.hiko.software
